# Dsremo Telemetry Detection — production env template
# Copy to .env.detect on the SpaceAi EC2 and fill all values.
# NEVER commit .env.detect to git.

# ── Database ──────────────────────────────────────────────────────────────────
DETECT_DB_NAME=dsremo
DETECT_DB_USER=dsremo
DETECT_DB_PASSWORD=GENERATE_WITH: openssl rand -hex 32

# ── Security ──────────────────────────────────────────────────────────────────
DETECT_JWT_SECRET=GENERATE_WITH: openssl rand -hex 32

# ── Optional: alerts (fill if you want email/webhook alerts) ─────────────────
# DSREMO_ALERTS__WEBHOOK_URL=https://hooks.slack.com/...
# DSREMO_ALERTS__SMTP_HOST=smtp.gmail.com
# DSREMO_ALERTS__SMTP_PORT=587
# DSREMO_ALERTS__SMTP_USER=your@email.com
# DSREMO_ALERTS__SMTP_PASSWORD=your_app_password
