# Dsremo Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.

# Database
DSREMO_DB_HOST=localhost
DSREMO_DB_USER=sentinel
DSREMO_DB_PASSWORD=changeme_use_strong_password

# Security
DSREMO_HMAC_SECRET=changeme_generate_with_openssl_rand
DSREMO_API_KEYS=[]  # JSON array of hashed keys — generate via CLI

# External Data APIs
SATNOGS_API_TOKEN=  # Get from https://db.satnogs.org/ → your profile

# Alerts (optional)
DSREMO_WEBHOOK_URL=
DSREMO_SMTP_HOST=
DSREMO_SMTP_USER=
DSREMO_SMTP_PASSWORD=
