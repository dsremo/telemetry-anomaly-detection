# Sentinel Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.

# Database
SENTINEL_DB_HOST=localhost
SENTINEL_DB_USER=sentinel
SENTINEL_DB_PASSWORD=changeme_use_strong_password

# Security
SENTINEL_HMAC_SECRET=changeme_generate_with_openssl_rand
SENTINEL_API_KEYS=[]  # JSON array of hashed keys — generate via CLI

# Alerts (optional)
SENTINEL_WEBHOOK_URL=
SENTINEL_SMTP_HOST=
SENTINEL_SMTP_USER=
SENTINEL_SMTP_PASSWORD=
